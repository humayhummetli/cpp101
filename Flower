#include <iostream>
using namespace std;
string flower(int );
int main() {
    int t;
    cin >> t;

    while(t--) {
        int k;
        cin >> k;
        cout << flower(k) << endl; }

    return 0;
}

string flower(int k) {
    if(k % 3 == 1)
        return "VGC";
    else if(k % 3 == 2)
        return "CVG";
    else
        return "GCV";
}
